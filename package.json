{
  "name": "daytona-npm-watch",
  "version": "0.1.0",
  "description": "Run npm install in a disposable Daytona sandbox and report suspicious install behavior.",
  "type": "module",
  "bin": {
    "daytona-npm-watch": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@daytona/sdk": "^0.191.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
